# MI-SOAR-NGFW Environment Variables
# Copy to .env and adjust values for your deployment

# Project
COMPOSE_PROJECT_NAME=mi-soar-ngfw

# Network
DOCKER_NETWORK=mi-soar-network
DOCKER_SUBNET=10.10.0.0/24

# Suricata
SURICATA_VERSION=7.0.2
SURICATA_IFACE=eth0

# WireGuard
WG_VERSION=latest
WG_SERVER_ADDRESS=10.10.1.1/24
WG_SERVER_PORT=51820
WG_PEERS=10
WG_ALLOWED_IPS=0.0.0.0/0

# OPNsense + OpenVPN (preferred production-like lab path)
OPNSENSE_BASE_URL=https://opnsense.local
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=
OPENVPN_ENABLED=true
OPENVPN_TUNNEL_CIDR=10.8.0.0/24

# Wazuh
WAZUH_VERSION=4.7.3
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=change-this-wazuh-password

# n8n
N8N_VERSION=2.11.3
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=https://your-domain.com
N8N_ENCRYPTION_KEY=change-this-n8n-encryption-key
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=
FIREWALL_API_URL=http://mock-firewall:8080
FIREWALL_DASHBOARD_TOKEN=

# Traefik
TRAEFIK_VERSION=v3.0
TRAEFIK_API_DASHBOARD=true
TRAEFIK_API_INSECURE=false

# Security
TLS_ENABLED=false
CERTIFICATE_PATH=/etc/ssl/certs

# Logging
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
MOCK_FIREWALL_PORT=8081

# Storage paths (relative to project root)
STORAGE_PATH=./storage
LOGS_PATH=./storage/logs
CONFIGS_PATH=./configs
