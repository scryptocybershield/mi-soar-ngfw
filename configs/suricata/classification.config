# Classification configuration for Suricata
# Maps alert signatures to categories

config classification: not-suspicious,Not Suspicious Traffic,3
config classification: unknown,Unknown Traffic,3
config classification: bad-unknown,Potentially Bad Traffic,2
config classification: attempted-recon,Attempted Information Leak,2
config classification: successful-recon,Information Leak,2
config classification: attempted-dos,Attempted Denial of Service,2
config classification: successful-dos,Denial of Service,2
config classification: attempted-user,Attempted User Privilege Gain,1
config classification: unsuccessful-user,Unsuccessful User Privilege Gain,1
config classification: successful-user,Successful User Privilege Gain,1
config classification: attempted-admin,Attempted Administrator Privilege Gain,1
config classification: successful-admin,Successful Administrator Privilege Gain,1

# MI-SOAR-NGFW custom classifications
config classification: mi-soar-ngfw-scan,Network Scan Detected,2
config classification: mi-soar-ngfw-malware,Malware Communication,1
config classification: mi-soar-ngfw-exploit,Exploit Attempt,1
config classification: mi-soar-ngfw-data-exfiltration,Data Exfiltration,1